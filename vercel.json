{
  "installCommand": "cd uniconnect/client && npm install",
  "buildCommand": "cd uniconnect/client && npm run build",
  "outputDirectory": "uniconnect/client/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://uniconnect-2-l966.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://uniconnect-2-l966.onrender.com/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
